# =============================================
# CarbonTrack – .gitignore
# =============================================

# ── Environment & Secrets ─────────
.env
.env.*
!.env.example

# ── Java / Maven ──────────────────
target/
*.class
*.jar
*.war
*.ear
*.log

# ── IDE ───────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
nbproject/
*.swp
*.swo

# ── Node / Frontend ──────────────
node_modules/
dist/
build/
coverage/
.cache/
.parcel-cache/

# ── OS Files ─────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.bak
*.tmp
*.temp

# ── Logs ─────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ───────────────────────
docker-compose.override.yml
