# ================================
# CarbonTrack Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Database ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carbontrack
DB_USER=postgres
DB_PASSWORD=

# ── Redis ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Security ──────────────────
JWT_SECRET=

# ── Google OAuth2 ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend Email Configuration ────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Cohere AI API ────────────────
COHERE_API_KEY=

# ── Frontend URL (for CORS/OAuth) ─
FRONTEND_URL=http://localhost:5173
