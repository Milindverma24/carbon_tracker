# ================================
# CarbonTrack Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Database ──────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=carbontrack
DB_USER=root
DB_PASSWORD=

# ── Redis ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Security ──────────────────
JWT_SECRET=

# ── Google OAuth2 ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Brevo SMTP (Email) ───────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=YOUR_BREVO_EMAIL
BREVO_SMTP_PASSWORD=YOUR_BREVO_SMTP_PASSWORD

# ── Cohere AI API ────────────────
COHERE_API_KEY=

# ── Frontend URL (for CORS/OAuth) ─
FRONTEND_URL=http://localhost:5173
